-- Settings
local HoldClick = false
local Hotkey = 'r' -- Toggle key
local HotkeyToggle = true 
local Players = game:GetService('Players')
local RunService = game:GetService('RunService')

-- Robust LocalPlayer & Mouse Waiting (for Auto-Execute)
local LocalPlayer = Players.LocalPlayer
while not LocalPlayer do
    task.wait(0.1)
    LocalPlayer = Players.LocalPlayer
end

local Mouse = nil
while not Mouse do
    task.wait(0.1)
    pcall(function()
        Mouse = LocalPlayer:GetMouse()
    end)
end

local Toggle = false  -- Starts OFF
local CurrentlyPressed = false

-- Team & Health Check
local TeamCheck = false

-- Tiny indicator GUI
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui", 10)
local Gui = Instance.new("ScreenGui")
Gui.Name = "ToggleIndicator"
Gui.ResetOnSpawn = false
Gui.Parent = PlayerGui

local Indicator = Instance.new("Frame")
Indicator.Size = UDim2.new(0, 2, 0, 3) -- 2x3 pixel
Indicator.Position = UDim2.new(0, 5, 1, -15)
Indicator.BorderSizePixel = 0
Indicator.Parent = Gui

local function UpdateIndicator()
    Indicator.BackgroundColor3 = Toggle
        and Color3.fromRGB(0, 255, 0)
        or Color3.fromRGB(255, 0, 0)
end
UpdateIndicator()

Mouse.KeyDown:Connect(function(key)
    if HotkeyToggle == true and key == Hotkey then
        Toggle = not Toggle
        UpdateIndicator()
    elseif key == Hotkey then
        Toggle = true
        UpdateIndicator()
    end
end)

Mouse.KeyUp:Connect(function(key)
    if HotkeyToggle ~= true and key == Hotkey then
        Toggle = false
        UpdateIndicator()
    end
end)

RunService.RenderStepped:Connect(function()
    if Toggle then
        if Mouse.Target and Mouse.Target.Parent then
            local targetChar = Mouse.Target.Parent
            local humanoid = targetChar:FindFirstChild('Humanoid')
            
            if humanoid and humanoid.Health > 0 then
                
                if TeamCheck then
                    local targetPlayer = Players:GetPlayerFromCharacter(targetChar)
                    if targetPlayer and targetPlayer.Team == LocalPlayer.Team then
                        if HoldClick and CurrentlyPressed then
                            CurrentlyPressed = false
                            mouse1release()
                        end
                        return
                    end
                end
                
                if HoldClick then
                    if not CurrentlyPressed then
                        CurrentlyPressed = true
                        mouse1press()
                    end
                else
                    mouse1click()
                end
            else
                if HoldClick and CurrentlyPressed then
                    CurrentlyPressed = false
                    mouse1release()
                end
            end
        elseif HoldClick and CurrentlyPressed then
            CurrentlyPressed = false
            mouse1release()
        end
    end
end)

print("Loaded Successfully!")
