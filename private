-- === CONFIGURABLE ===

local Config = _G.TriggerbotConfig or {
    HoldClick = true,
    TeamCheck = false,     -- Change this from outside
    Delay = 0.12,
    Hotkey = 'r',
    IndicatorTransparency = 0.6,
}

local Players = game:GetService('Players')
local RunService = game:GetService('RunService')

-- Robust Load
local LocalPlayer = Players.LocalPlayer
while not LocalPlayer do task.wait(0.1) LocalPlayer = Players.LocalPlayer end

local Mouse = LocalPlayer:GetMouse()
while not Mouse do task.wait(0.1) pcall(function() Mouse = LocalPlayer:GetMouse() end) end

local Toggle = false
local CurrentlyPressed = false

-- Tiny Indicator
local Gui = Instance.new("ScreenGui")
Gui.ResetOnSpawn = false
Gui.Parent = LocalPlayer:WaitForChild("PlayerGui")

local Indicator = Instance.new("Frame")
Indicator.Size = UDim2.new(0, 2, 0, 3)
Indicator.Position = UDim2.new(0, 5, 1, -15)
Indicator.BorderSizePixel = 0
Indicator.BackgroundTransparency = Config.IndicatorTransparency
Indicator.Parent = Gui

local function UpdateIndicator()
    Indicator.BackgroundColor3 = Toggle and Color3.fromRGB(0,255,0) or Color3.fromRGB(255,0,0)
end
UpdateIndicator()

Mouse.KeyDown:Connect(function(key)
    if key == Config.Hotkey then
        Toggle = not Toggle
        UpdateIndicator()
    end
end)

RunService.RenderStepped:Connect(function()
    if not Toggle then 
        if Config.HoldClick and CurrentlyPressed then
            CurrentlyPressed = false
            mouse1release()
        end
        return 
    end

    if Mouse.Target and Mouse.Target.Parent then
        local targetChar = Mouse.Target.Parent
        local hum = targetChar:FindFirstChild("Humanoid")
        
        if hum and hum.Health > 0 then
            
            if Config.TeamCheck then
                local tp = Players:GetPlayerFromCharacter(targetChar)
                if tp and ((LocalPlayer.Team and tp.Team == LocalPlayer.Team) or (LocalPlayer.TeamColor == tp.TeamColor)) then
                    return
                end
            end

            if Config.HoldClick then
                if not CurrentlyPressed then
                    CurrentlyPressed = true
                    mouse1press()
                end
            else
                mouse1click()
                if Config.Delay > 0 then task.wait(Config.Delay) end
            end
        else
            if Config.HoldClick and CurrentlyPressed then
                CurrentlyPressed = false
                mouse1release()
            end
        end
    elseif Config.HoldClick and CurrentlyPressed then
        CurrentlyPressed = false
        mouse1release()
    end
end)

print("!!")
